{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "include": ["src/**/*"]
}
